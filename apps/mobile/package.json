{
  "name": "@cabinconnect/mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_ROUTER_APP_ROOT=src/app expo start",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "lint": "tsc --noEmit",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/expo-router/_ctx.web.js',c=fs.readFileSync(p,'utf8').replace(/(require\\.context\\()\\s*'[^']*'/,'$1\\'../../src/app\\'');fs.writeFileSync(p,c);\""
  },
  "dependencies": {
    "@cabinconnect/shared": "*",
    "@expo/metro-runtime": "^3.2.3",
    "@supabase/supabase-js": "^2.43.0",
    "expo": "~51.0.0",
    "expo-asset": "~10.0.10",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "i18next": "^23.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^14.0.0",
    "react-native": "0.74.5",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@types/react": "~18.2.0",
    "typescript": "~5.3.3"
  }
}
