{
  "expo": {
    "name": "CabinConnect",
    "slug": "cabinconnect",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cabinconnect",
    "platforms": ["ios", "android", "web"],
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Used to find nearby suppliers" }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.99x.cabinconnect"
    },
    "android": {
      "package": "com.x99.cabinconnect"
    }
  }
}
